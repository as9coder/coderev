# GitHub App webhook server (see README → GitHub App)
GITHUB_APP_ID=123456
# PEM contents: paste full key, or single line with \n for newlines
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-random-secret
OPENROUTER_API_KEY=
CODEREV_ALLOWED_USER=your-github-username
MODEL=minimax/minimax-m2.7
